# =============================================================================
# Chat Orchestrator — Environment Variables
# =============================================================================
# Local dev:  cp .env.example .env  (from the services/ workspace root)
# Production: fly secrets set KEY=value  (for secrets marked with *)

# --- LLM Provider ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY          # * required — OpenAI API key

# --- LLM Models ---
CHAT_LLM_MODEL=gpt-4o
CHAT_LLM_FALLBACK_MODEL=gpt-4o-mini
CHAT_LLM_EMERGENCY_MODEL=gpt-3.5-turbo

# --- Internal Service URLs ---
CHAT_RAG_SERVICE_URL=http://localhost:8002  # * production: internal Fly.io URL, e.g. http://trenkwalder-rag-service.internal:8000
CHAT_HR_SERVICE_URL=http://localhost:8003   # * production: internal Fly.io URL, e.g. http://trenkwalder-hr-service.internal:8000

# --- Redis ---
CHAT_REDIS_URL=redis://localhost:6379/0     # * production: e.g. Upstash Redis URL or Fly.io Redis internal URL

# --- Shared ---
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]      # * production: e.g. '["https://trenkwalder-frontend.fly.dev"]'
