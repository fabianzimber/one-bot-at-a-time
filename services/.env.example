# =============================================================================
# Trenkwalder AI Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Chat Orchestrator ---
CHAT_REDIS_URL=redis://localhost:6379/0
CHAT_RAG_SERVICE_URL=http://localhost:8002
CHAT_HR_SERVICE_URL=http://localhost:8003
CHAT_LLM_MODEL=gpt-4o
CHAT_LLM_FALLBACK_MODEL=gpt-4o-mini
CHAT_LLM_EMERGENCY_MODEL=gpt-3.5-turbo

# --- RAG Service ---
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8004
RAG_EMBEDDING_MODEL=text-embedding-3-small

# --- HR Service ---
HR_DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/trenkwalder_hr

# --- Shared ---
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
