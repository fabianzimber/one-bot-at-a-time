# =============================================================================
# HR Service — Environment Variables
# =============================================================================
# Local dev:  cp .env.example .env  (from the services/ workspace root)
# Production: fly secrets set KEY=value  (for secrets marked with *)

# --- Database ---
# Local dev uses SQLite (default); production uses PostgreSQL via Fly Postgres.
# Provision a cluster with: fly postgres create --name trenkwalder-pg --region fra
# Then attach with:         fly postgres attach trenkwalder-pg
HR_DATABASE_URL=sqlite+aiosqlite:///./hr_data.db
# HR_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/trenkwalder_hr  # * production

# --- Seed Data ---
HR_SEED_EMPLOYEE_COUNT=50

# --- Shared ---
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]      # * production: e.g. '["https://trenkwalder-frontend.fly.dev"]'
