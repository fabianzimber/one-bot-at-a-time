# =============================================================================
# RAG Service — Environment Variables
# =============================================================================
# Local dev:  cp .env.example .env  (from the services/ workspace root)
# Production: fly secrets set KEY=value  (for secrets marked with *)

# --- LLM Provider ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY          # * required — used for embedding generation

# --- ChromaDB ---
RAG_CHROMA_HOST=localhost                   # * production: internal Fly.io hostname, e.g. trenkwalder-chromadb.internal
RAG_CHROMA_PORT=8004                        # * production: internal port, typically 8000
RAG_CHROMA_COLLECTION=trenkwalder_docs

# --- Embedding ---
RAG_EMBEDDING_MODEL=text-embedding-3-small

# --- Chunking ---
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# --- Upload Limits ---
RAG_MAX_FILE_SIZE_MB=10
RAG_ALLOWED_EXTENSIONS=[".pdf", ".txt", ".md", ".docx"]

# --- Shared ---
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]      # * production: e.g. '["https://trenkwalder-frontend.fly.dev"]'
